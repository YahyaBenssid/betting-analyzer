# ============================================================
# BETTING ANALYZER PRO — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- The Odds API (gratuite, 500 req/mois) ---
# Obtenir une clé sur https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# --- football-data.org (gratuite, 10 req/min) ---
# Obtenir une clé sur https://www.football-data.org/
# Ligues supportées : PL, PD, BL1, SA, FL1, CL, PPL, ELC, DED
# Stats chargées : standings saison + 10 derniers matchs par équipe
# Cache disque 24h → ~5 appels API par ligue au démarrage seulement
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# --- Cache ---
# "redis" ou "shelve" (fallback sans Redis)
CACHE_BACKEND=shelve
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

# --- Scraper ---
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
# Délai entre requêtes (secondes)
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0
# Nombre de retries
SCRAPER_MAX_RETRIES=3

# --- Analyse ---
# EV minimum pour considérer un value bet (%)
MIN_EV_THRESHOLD=3.0
# Score de confiance minimum (0-100)
MIN_CONFIDENCE_SCORE=60
# Fraction Kelly utilisée (0.25 = Kelly/4)
KELLY_FRACTION=0.25
# Bankroll de référence (€)
DEFAULT_BANKROLL=1000.0

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
# Intervalle de rafraîchissement (secondes)
REFRESH_INTERVAL=60

# --- Logs ---
LOG_LEVEL=INFO
LOG_FILE=logs/betting_analyzer.log
